# Placement target name or frame id.
string target_id

# Optional object id for bookkeeping. Empty uses the currently held object.
string object_id

# Optional motion parameters. Values <= 0 use server defaults.
float64 hover_height
float64 release_height
float64 lift_height
float64 timeout
